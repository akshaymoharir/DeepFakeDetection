# ============================================================
# Environment Variables — DeepFakeDetection
# ============================================================
# Copy this file to .env and adjust paths for your system.
#   cp .env.example .env
#
# docker-compose and start_container.sh read these values.
# ============================================================

# Path to your dataset directory on the HOST machine
# This gets mounted to /workspace/data inside the container
DATA_DIR=/path/to/your/datasets

# GPU selection (if you have multiple GPUs)
CUDA_VISIBLE_DEVICES=0

# Weights & Biases (optional)
# WANDB_API_KEY=your_key_here
